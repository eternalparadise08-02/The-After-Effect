<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Premium Secure Access</title>
<style>
  /* ---------- Global Styles ---------- */
  * { box-sizing: border-box; margin: 0; padding: 0; font-family: 'Poppins', sans-serif; }
  body {
    height: 100vh;
    display: flex;
    justify-content: center;
    align-items: center;
    background: linear-gradient(135deg, #6a11cb 0%, #2575fc 100%);
    overflow: hidden;
  }

  /* ---------- Animated Background Circles ---------- */
  .circle {
    position: absolute;
    border-radius: 50%;
    opacity: 0.2;
    animation: float 15s infinite;
    pointer-events: none; /* allow interaction */
  }
  .circle:nth-child(1){width: 300px; height:300px; background:#fff; top:10%; left:15%;}
  .circle:nth-child(2){width:200px; height:200px; background:#ff6a00; top:70%; left:70%;}
  .circle:nth-child(3){width:400px; height:400px; background:#00ffea; top:40%; left:80%;}
  @keyframes float {
    0%, 100% {transform: translateY(0);}
    50% {transform: translateY(-50px);}
  }

  /* ---------- Card Container ---------- */
  .card {
    position: relative;
    z-index: 10;
    background: #1e1e2f;
    padding: 40px 30px;
    border-radius: 25px;
    width: 380px;
    box-shadow: 0 20px 40px rgba(0,0,0,0.4);
    color: #fff;
    text-align: center;
    transition: transform 0.3s, box-shadow 0.3s;
  }
  .card:hover {
    transform: translateY(-10px);
    box-shadow: 0 30px 60px rgba(0,0,0,0.5);
  }

  h2 {
    font-size: 24px;
    margin-bottom: 30px;
    letter-spacing: 1px;
  }

  /* ---------- Input ---------- */
  .input-group {
    position: relative;
    margin-bottom: 25px;
  }
  input[type="password"], input[type="text"] {
    width: 100%;
    padding: 15px 45px 15px 20px;
    border-radius: 15px;
    border: none;
    outline: none;
    font-size: 16px;
    background: #2e2e44;
    color: #fff;
    transition: 0.3s;
  }
  input[type="password"]:focus, input[type="text"]:focus {
    background: #3c3c5c;
  }

  /* ---------- Show/Hide Button ---------- */
  #toggle {
    position: absolute;
    right: 15px;
    top: 50%;
    transform: translateY(-50%);
    background: none;
    border: none;
    color: #00ffe5;
    font-size: 18px;
    cursor: pointer;
    transition: transform 0.3s;
  }
  #toggle:hover { transform: translateY(-50%) scale(1.2); }

  /* ---------- Buttons ---------- */
  button {
    width: 100%;
    padding: 15px;
    margin-bottom: 15px;
    border-radius: 15px;
    font-size: 16px;
    font-weight: bold;
    cursor: pointer;
    border: none;
    color: #fff;
    background: linear-gradient(90deg, #ff6a00 0%, #ee0979 100%);
    transition: 0.3s;
    box-shadow: 0 8px 20px rgba(0,0,0,0.3);
  }
  button:hover {
    transform: scale(1.05);
    box-shadow: 0 12px 25px rgba(0,0,0,0.5);
  }
  #login { background: linear-gradient(90deg, #00f260 0%, #0575e6 100%); }
  #forgot { background: linear-gradient(90deg, #ff512f 0%, #dd2476 100%); }

  /* ---------- Message ---------- */
  #message {
    min-height: 22px;
    font-size: 14px;
    color: #ff4b5c;
    margin-top: 10px;
    letter-spacing: 0.5px;
  }
</style>
</head>
<body>

<!-- Background Circles -->
<div class="circle"></div>
<div class="circle"></div>
<div class="circle"></div>

<div class="card">
  <h2>Premium Secure Access</h2>
  <div class="input-group">
    <input type="password" id="password" placeholder="Enter password">
    <button id="toggle">👁️</button>
  </div>
  <button id="setPassword">Set Password</button>
  <button id="login" disabled>Login</button>
  <button id="forgot" disabled>Forgot Password</button>
  <p id="message"></p>
</div>

<script>
  let storedHash = null;
  let attempts = 0;
  const MAX_ATTEMPTS = 3;

  const passwordInput = document.getElementById("password");
  const toggleBtn = document.getElementById("toggle");
  const setBtn = document.getElementById("setPassword");
  const loginBtn = document.getElementById("login");
  const forgotBtn = document.getElementById("forgot");
  const message = document.getElementById("message");

  // Show/Hide password
  toggleBtn.addEventListener("click", () => {
    if(passwordInput.type === "password") {
      passwordInput.type = "text";
      toggleBtn.textContent = "🙈";
    } else {
      passwordInput.type = "password";
      toggleBtn.textContent = "👁️";
    }
  });

  // Simple hash function (demo)
  function hashPassword(password) { return btoa(password); }

  // Password validation
  function checkNextRequirement(password) {
    if(password.length < 8) return "Password must be at least 8 characters.";
    if(!/[a-z]/.test(password)) return "Use at least one lowercase letter.";
    if(!/[A-Z]/.test(password)) return "Use at least one uppercase letter.";
    if(!/[0-9]/.test(password)) return "Use at least one number.";
    if(!/[!@#$%^&*()\[\]{}<>?]/.test(password)) return "Use at least one special character.";
    return null;
  }

  // Strong password generator
  function generateStrongPassword(length=12) {
    const upper = "ABCDEFGHIJKLMNOPQRSTUVWXYZ";
    const lower = "abcdefghijklmnopqrstuvwxyz";
    const digits = "0123456789";
    const special = "!@#$%^&*()[]{}<>?";
    let pwd = [
      upper[Math.floor(Math.random()*upper.length)],
      lower[Math.floor(Math.random()*lower.length)],
      digits[Math.floor(Math.random()*digits.length)],
      special[Math.floor(Math.random()*special.length)]
    ];
    const all = upper + lower + digits + special;
    for(let i=4;i<length;i++) pwd.push(all[Math.floor(Math.random()*all.length)]);
    return pwd.sort(()=>Math.random()-0.5).join("");
  }

  // Set password
  setBtn.addEventListener("click", () => {
    const pwd = passwordInput.value;
    const msg = checkNextRequirement(pwd);
    if(msg) { message.textContent = msg; }
    else {
      storedHash = hashPassword(pwd);
      message.textContent = "";
      alert("✅ Password set successfully!");
      passwordInput.value = "";
      setBtn.disabled = true;
      loginBtn.disabled = false;
      forgotBtn.disabled = false;
    }
  });

  // Login
  loginBtn.addEventListener("click", () => {
    const pwd = passwordInput.value;
    if(hashPassword(pwd) === storedHash) {
      alert("🔐 Welcome! Sensitive data unlocked.");
      passwordInput.value = "";
    } else {
      attempts++;
      const remaining = MAX_ATTEMPTS - attempts;
      if(remaining > 0) alert(`🚫 Incorrect password! Attempts left: ${remaining}`);
      else {
        alert("⛔ System locked. Too many failed attempts.");
        loginBtn.disabled = true;
        forgotBtn.disabled = true;
        setBtn.disabled = false;
      }
      passwordInput.value = "";
    }
  });

  // Forgot password
  forgotBtn.addEventListener("click", () => {
    const strongPwd = generateStrongPassword();
    passwordInput.value = strongPwd;
    alert(`Suggested strong password:\n${strongPwd}`);
  });

  // ---------------- ENTER KEY SUPPORT ----------------
  passwordInput.addEventListener("keypress", function(event) {
    if (event.key === "Enter") {
      event.preventDefault();
      if (!setBtn.disabled) {
        setBtn.click();
      } else if (!loginBtn.disabled) {
        loginBtn.click();
      }
    }
  });
</script>

</body>
</html>
